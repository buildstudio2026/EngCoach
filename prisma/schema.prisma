generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  expressions Expression[]
  conversations Conversation[]
  suggestions Suggestion[]
}

model Expression {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  expression  String
  priority    Int      @default(2) // 3 = high (AI), 2 = user, 1 = low
  mastery     Int      @default(0) // 0-3
  createdAt   DateTime @default(now())
  lastUsed    DateTime?
}

model Conversation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  question   String
  userAnswer String?
  createdAt  DateTime @default(now())
}

model Suggestion {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  expression String
  type       String
  createdAt  DateTime @default(now())
}
