generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Expression {
  id          String   @id @default(cuid())
  userId      String
  expression  String
  meaning     String?
  explanation String?
  type        String?  // alternative, expression, grammar
  priority    Int      @default(2)
  mastery     Int      @default(0)
  createdAt   DateTime @default(now())
  lastUsed    DateTime?

  @@index([userId])
}

model Conversation {
  id         String   @id @default(cuid())
  userId     String
  question   String
  meaning    String?
  example          String?
  targetExpression String?
  userAnswer       String?
  createdAt        DateTime @default(now())

  @@index([userId])
}

model Suggestion {
  id          String   @id @default(cuid())
  userId      String
  original    String?
  expression  String
  type        String
  meaning     String?
  explanation String?
  createdAt   DateTime @default(now())

  @@index([userId])
}
